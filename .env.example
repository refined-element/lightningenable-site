# Lightning Enable Demo — env vars
# Copy to .env for local dev (`vercel dev`), or set these in the Vercel
# project settings before deploying to production.

# 1. The Lightning Enable merchant API key for the demo merchant.
#    Get one from https://api.lightningenable.com/dashboard/settings.
#    The merchant must be on the Agentic Commerce plan (Individual or Business)
#    and have a payment provider (Strike or OpenNode) configured.
LIGHTNING_ENABLE_API_KEY=

# 2. NWC connection URL for the demo's agent wallet. This is the wallet that
#    pays invoices on the visitor's behalf. Fund it with a small balance
#    (e.g. 5,000 sats) at https://coinos.io/ or any other NWC-capable wallet,
#    then paste the nostr+walletconnect:// URL here.
DEMO_AGENT_NWC_URL=

# 3. (Optional) Override the LE API base URL. Defaults to prod.
#    LIGHTNING_ENABLE_API_BASE_URL=https://api.lightningenable.com
